@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="_content/KG.MES.UI.Shared/images/logo_white.png" class="sidebar-logo" />
            <span>Красная горка</span>
        </div>
        
        <nav class="sidebar-nav">
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <i class="bi bi-clipboard-check"></i>
                <span>Заказы в производстве</span>
            </NavLink>

            <NavLink class="nav-item" href="upload">
                <i class="bi bi-bar-chart"></i>
                <span>Загрузить XML</span>
            </NavLink>

            <NavLink class="nav-item" href="create-order">
                <i class="bi bi-clipboard-check"></i>
                <span>Новый заказ</span>
            </NavLink>
            
            <NavLink class="nav-item" href="workplace-stats">
                <i class="bi bi-bar-chart"></i>
                <span>Статистика участков</span>
            </NavLink>
        </nav>
    </aside>

    <main>
        @Body
    </main>
</div>

<style>
.page {
    display: flex;
    height: 100vh;
    background: #f5f6f8;
}

.sidebar {
    width: 260px;
    background: #1a1d23;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    color: #b0b5c0;
}

.sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 1.25rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: white;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.sidebar-brand i {
    font-size: 1.4rem;
    color: #4f8ff7;
}

.sidebar-nav {
    flex: 1;
    padding: 1rem 0.75rem;
}

.nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    border-radius: 0.5rem;
    color: #9095a0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.15s;
}

.nav-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: #d0d4dc;
}

.nav-item.active {
    background: rgba(79, 143, 247, 0.12);
    color: #4f8ff7;
}

.nav-item i {
    font-size: 1.15rem;
    width: 24px;
    text-align: center;
}

main {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
}

.sidebar-logo {
    width: 64px;
    height: 64px;
    object-fit: contain;
}

</style>