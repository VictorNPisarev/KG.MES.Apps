@if (isLoading)
{
	<div class="text-center py-3">
		<div class="spinner-border spinner-border-sm text-primary" role="status"></div>
	</div>
}
else
{
	<div class="comments-panel">
		<div class="d-flex justify-content-between align-items-center mb-2">
			<h6 class="trace-title"><i class="bi bi-chat-left-text"></i> Комментарии</h6>
			<button class="btn btn-sm btn-link text-secondary p-0" @onclick="AddNewComment">
				<i class="bi bi-plus-lg"></i>
			</button>
		</div>

		@if (comments.Any())
		{
			<div class="comments-list">
				@foreach (var c in comments.OrderByDescending(c => c.CreatedAt))
				{
					<div class="comment-item @(c.IsEditing ? "editing" : "")">
						<div class="comment-header">
							<span class="comment-date">@c.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</span>
							@if (!string.IsNullOrEmpty(c.UserName))
							{
								<span class="comment-user ms-2">— @c.UserName</span>
							}
							@if (c.UpdatedAt.HasValue)
							{
								<span class="text-muted small ms-2">(изменено)</span>
							}
							<div class="comment-actions ms-auto">
								@if (c.IsEditing)
								{
									<button class="btn btn-sm btn-link text-success p-0" @onclick="() => SaveComment(c)">
										<i class="bi bi-check-lg"></i>
									</button>
									<button class="btn btn-sm btn-link text-secondary p-0" @onclick="() => CancelEditComment(c)">
										<i class="bi bi-x-lg"></i>
									</button>
								}
								else
								{
									<button class="btn btn-sm btn-link text-secondary p-0" @onclick="() => EditComment(c)">
										<i class="bi bi-pencil"></i>
									</button>
									<!--<button class="btn btn-sm btn-link text-danger p-0" @onclick="() => DeleteComment(c)">
										<i class="bi bi-trash"></i>
													</button>-->
								}
							</div>
						</div>
						<div class="comment-body">
							@if (c.IsEditing)
							{
								<textarea class="form-control form-control-sm auto-grow" @bind="c.Content" rows="1"
									style="resize: none; overflow: hidden;"></textarea>
							}
							else
							{
								<p class="mb-0">@c.Content</p>
							}
						</div>
					</div>
				}
			</div>
		}
		else
		{
			<p class="text-muted small mb-0">Нет комментариев</p>
		}
	</div>
}
