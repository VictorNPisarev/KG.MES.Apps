@using KG.MES.Shared.Helpers
@using KG.MES.Shared.Models.Dto
@using KG.MES.Shared.Services
@using Microsoft.JSInterop

@inject ProductionApiService ApiService
@inject SupplyService SupplyService
@inject OrderSupplyDtoFactory SupplyFactory
@inject IJSRuntime JSRuntime

@if (isLoading)
{
	<div class="text-center py-3">
		<div class="spinner-border spinner-border-sm text-primary" role="status"></div>
	</div>
}
else
{
	@if (supplies.Any())
	{
		<div class="supplies-panel">
			<div class="d-flex justify-content-between align-items-center mb-2">
				<h6 class="trace-title"><i class="bi bi-box-seam"></i> Снабжение</h6>
				<div class="d-flex gap-1">
					@if (EditMode)
					{
						<button class="btn btn-sm btn-link text-secondary p-0" @onclick="SaveChanges">
							<i class="bi bi-check-lg"></i>
						</button>
						<button class="btn btn-sm btn-link text-secondary p-0" @onclick="CancelEdit">
							<i class="bi bi-x-lg"></i>
						</button>
					}
					else if (CanEdit)
					{
						<button class="btn btn-sm btn-link text-secondary p-0" @onclick="EnterEditMode">
							<i class="bi bi-pencil"></i>
						</button>
					}
				</div>
			</div>
			<table class="supplies-table">
				<tbody>
					@foreach (var s in supplies)
					{
						<tr>
							<td class="supplies-material">@s.SupplyType?.DisplayName()</td>
							<td class="supplies-status">
								<div class="d-flex align-items-center gap-1">
									@if (EditMode)
									{
										<div class="dropdown">
											<span class="badge @(BadgeHelper.GetBadgeClass(s.SupplyCondition?.ConditionCode) ?? "bg-light text-dark")"
												style="cursor: pointer;" data-bs-toggle="dropdown">
												@(s.SupplyCondition?.DisplayName() ?? "—")
												<i class="bi bi-chevron-down ms-1 small"></i>
											</span>
											<ul class="dropdown-menu">
												@foreach (var c in conditions)
												{
													<li>
														<a class="dropdown-item" @onclick="() => s.SupplyConditionId = c.Id">
															<span class="badge @BadgeHelper.GetBadgeClass(c.ConditionCode)">@c.DisplayName()</span>
														</a>
													</li>
												}
											</ul>
										</div>
									}
									else if (!string.IsNullOrEmpty(s.SupplyConditionId))
									{
										<span class="badge @BadgeHelper.GetBadgeClass(s.SupplyCondition?.ConditionCode)">
											@s.SupplyCondition?.DisplayName()
										</span>
									}
									else
									{
										<span class="text-muted">—</span>
									}

									@* Кнопка комментария *@
									@if (showComments.GetValueOrDefault(s.SupplyTypeId))
									{
										<button class="btn btn-sm btn-link text-success p-0"
												@onclick="() => SaveComment(s)" title="Сохранить">
											<i class="bi bi-check-lg"></i>
										</button>
									}
									else
									{
										<button class="btn btn-sm btn-link p-0 @(string.IsNullOrEmpty(s.Comment) ? "text-secondary" : "text-primary")"
												@onclick="() => ToggleComment(s)" title="Комментарий">
											<i class="bi bi-chat-left-text"></i>
											@if (!string.IsNullOrEmpty(s.Comment))
											{
												<small class="ms-1 text-primary" style="font-size: 0.7rem;">
													@(s.Comment.Length > 10 ? s.Comment[..10] + "…" : s.Comment)
												</small>
											}
										</button>
									}
								</div>

								@* Поле комментария *@
								@if (showComments.GetValueOrDefault(s.SupplyTypeId))
								{
									<div class="mt-1">
										<input class="form-control form-control-sm"
											   @bind="s.Comment"
											   placeholder="Примечание" />
									</div>
								}
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
	else
	{
		<p class="text-muted small mb-0">Нет данных о снабжении</p>
	}
}

@code {
	[Parameter] public Guid OrderId { get; set; }
	[Parameter] public bool CanEdit { get; set; }

	private List<OrderSupplyDto> supplies = new();
	private List<OrderSupplyDto> backup = new();
	private List<SupplyCondition> conditions = new();
	private List<SupplyType> types = new();

	private bool isLoading = true;
	private bool EditMode;
	private Dictionary<string, bool> showComments = new();

	protected override async Task OnInitializedAsync()
	{
		conditions = await SupplyService.GetConditionsAsync();
		types = await SupplyService.GetTypesAsync();
		supplies = await SupplyFactory.CreateAsync(OrderId, ApiService);

		isLoading = false;
	}

	private void EnterEditMode()
	{
		backup = supplies.Select(s => new OrderSupplyDto
		{
			SupplyTypeId = s.SupplyTypeId,
			SupplyConditionId = s.SupplyConditionId,
			Comment = s.Comment
		}).ToList();
		EditMode = true;
	}

	private void CancelEdit()
	{
		for (int i = 0; i < supplies.Count; i++)
		{
			supplies[i].SupplyConditionId = backup[i].SupplyConditionId;
			supplies[i].Comment = backup[i].Comment;
		}
		EditMode = false;
		showComments.Clear();
	}

	private async Task SaveChanges()
	{
		var updates = supplies.Select(s => new
		{
			supplyTypeId = s.SupplyTypeId,
			supplyConditionId = s.SupplyConditionId,
			comment = s.Comment
		}).ToList();

		var success = await ApiService.UpdateOrderSuppliesAsync(OrderId, updates);

		if (success)
		{
			EditMode = false;
			showComments.Clear();
			supplies = await ApiService.GetOrderSuppliesAsync(OrderId);
		}
	}

	private async Task SaveComment(OrderSupplyDto supply)
	{
		// Сохраняем только комментарий
		var success = await ApiService.UpdateOrderSuppliesAsync(OrderId, new List<object>
		{
			new
			{
				supplyTypeId = supply.SupplyTypeId,
				supplyConditionId = supply.SupplyConditionId,
				comment = supply.Comment
			}
		});
		
		if (success)
		{
			showComments.Remove(supply.SupplyTypeId);
		}
	}

	private void ToggleComment(OrderSupplyDto supply)
	{
		var key = supply.SupplyTypeId;
		showComments[key] = !showComments.GetValueOrDefault(key);
	}
}