@using KG.MES.Shared.Helpers
<PageTitle>Статистика рабочих мест</PageTitle>

<div class="container-fluid py-4">
	<h1 class="display-6 mb-4">
		<i class="bi bi-bar-chart"></i> Статистика рабочих мест
	</h1>

	@* Таблица участков с показателями *@
	<div class="card mb-4">
		<div class="card-header">
			<h6 class="mb-0">Участки</h6>
		</div>
		<div class="card-body p-0">
			<table class="table table-sm table-hover mb-0">
				<thead>
					<tr>
						<th>Участок</th>
						<th>Окна, шт</th>
						<th>Окна, м²</th>
						<th>Щитовые, шт</th>
						<th>Щитовые, м²</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var wp in workplaces)
					{
						<tr class="@(wp.Id == selectedWorkplaceId ? "table-active" : "")" 
								style='@(wp.IsWorkplace ? "cursor: pointer;" : "cursor: arrow;")' 
							@onclick="async () => { if (wp.IsWorkplace) await SelectWorkplace(wp.Id); else ClearSelection(); }">
							<td>
								@*<i class="bi @(wp.IsWorkplace ? "bi-gear" : "bi-flag") me-2"></i>*@
								@wp.Name
							</td>
							<td>@wp.WindowCount</td>
							<td>@wp.WindowArea.ToString("F2")</td>
							<td>@wp.PlateCount</td>
							<td>@wp.PlateArea.ToString("F2")</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>

	@* Статистика и история выбранного участка *@
	@if (selectedWorkplaceId != null && stats != null)
	{
		<div class="row g-2 mb-4">
			<div class="col-3">
				<div class="stat-card bg-warning bg-opacity-10">
					<div class="stat-number">@(stats.PendingCount + stats.JoineryCount)</div>
					<div class="stat-label">Ожидают</div>
				</div>
			</div>
			<div class="col-3">
				<div class="stat-card bg-primary bg-opacity-10">
					<div class="stat-number">@stats.ActiveCount</div>
					<div class="stat-label">В работе</div>
				</div>
			</div>
			<div class="col-3">
				<div class="stat-card bg-success bg-opacity-10">
					<div class="stat-number">@stats.CompletedCount</div>
					<div class="stat-label">Завершено</div>
				</div>
			</div>
		</div>

		<div class="card mb-3">
			<div class="card-header">
				<h6 class="mb-0">Заблокированные заказы</h6>
			</div>
			<div class="card-body p-0">
				@if (blocks.Any())
				{
					<table class="table table-sm mb-0">
						<thead>
							<tr>
								<th>Заказ</th>
								<th>Причина</th>
								<th>Дата</th>
								<th>Сотрудник</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var b in blocks)
							{
								<tr>
									<td>@b.OrderNumber</td>
									<td>@b.Reason</td>
									<td>@b.BlockedAt.ToString("dd.MM HH:mm")</td>
									<td>@b.UserName</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p class="text-muted small p-3">Нет заблокированных заказов</p>
				}
			</div>
		</div>

		<div class="card">
			<div class="card-header d-flex align-items-center">
				<h6 class="mb-0">
					История операций 
					<small class="text-muted ms-2">@dateFrom.ToString("dd.MM.yyyy") – @dateTo.ToString("dd.MM.yyyy")</small>
				</h6>
				<button class="btn btn-sm btn-link text-secondary p-0 ms-2" @onclick="() => showDateFilter = !showDateFilter">
					<i class="bi bi-calendar3"></i>
				</button>
			</div>
			
			@if (showDateFilter)
			{
				<div class="card-body bg-light border-bottom py-2">
					<div class="d-flex align-items-center gap-2">
						<label class="form-label small mb-0">С</label>
						<input type="date" class="form-control form-control-sm" style="width: auto;" @bind="dateFrom" />
						<label class="form-label small mb-0">По</label>
						<input type="date" class="form-control form-control-sm" style="width: auto;" @bind="dateTo" />
						<button class="btn btn-sm btn-primary" @onclick="ApplyFilter">Применить</button>
					</div>
				</div>
			}
			<div class="card-body p-0">
				@if (history.Any())
				{
					<table class="table table-sm mb-0">
						<thead>
							<tr>
								<th>Тип</th>
								<th>Заказ</th>
								<th>Сотрудник</th>
								<th>Время</th>
								<th>Примечание</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var h in history)
							{
								<tr>
									<td>
										<span class="badge @BadgeHelper.GetBadgeClass(h.OperationType.ToString())">
											@h.OperationType
										</span>
									</td>
									<td>@h.OrderNumber</td>
									<td>@h.UserName</td>
									<td>@h.OperationTime.ToString("dd.MM HH:mm")</td>
									<td>@h.Notes</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<p class="text-muted small p-3">Нет операций</p>
				}
			</div>
		</div>
	}
	else
	{
		<div class="text-center py-5 text-muted">
			<i class="bi bi-arrow-down display-4"></i>
			<p>Выберите участок для просмотра статистики</p>
		</div>
	}
</div>